<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Budgeteer.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:accounts="clr-namespace:Budgeteer.Accounts"
    xmlns:transactions="clr-namespace:Budgeteer.Transactions"
    Title="Budgeteer">

    <ShellContent
        Title="Accounts"
        Route="accounts"
        ContentTemplate="{DataTemplate accounts:AccountsPage}" />

    <ShellContent
        Title="Transactions"
        Route="transactions"
        ContentTemplate="{DataTemplate transactions:TransactionsPage}" />

</Shell>
