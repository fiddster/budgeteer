<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Budgeteer.Import.ImportPreviewPage"
             Title="Preview Import">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Valid transactions -->
                <Label Text="Transactions to import"
                       FontAttributes="Bold" FontSize="15" />

                <CollectionView x:Name="ValidList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="0,6" ColumnSpacing="12">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsIncluded}"
                                          VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="1">
                                    <Label Text="{Binding Transaction.Description}" FontSize="14" />
                                    <Label Text="{Binding Transaction.Date}" FontSize="12" TextColor="Gray" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="{Binding Transaction.Amount, StringFormat='{0:N2}'}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Duplicates -->
                <Label x:Name="DuplicatesHeader"
                       Text="Possible duplicates (already in database)"
                       FontAttributes="Bold" FontSize="15"
                       TextColor="Orange"
                       IsVisible="False" />

                <CollectionView x:Name="DuplicateList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,6" ColumnSpacing="12">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsIncluded}"
                                          VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="1">
                                    <Label Text="{Binding Transaction.Description}" FontSize="14" />
                                    <Label Text="{Binding Transaction.Date}" FontSize="12" TextColor="Gray" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="{Binding Transaction.Amount, StringFormat='{0:N2}'}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Error rows -->
                <Label x:Name="ErrorsHeader"
                       Text="Rows with errors (could not be parsed)"
                       FontAttributes="Bold" FontSize="15"
                       TextColor="Red"
                       IsVisible="False" />

                <CollectionView x:Name="ErrorList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="Red" StrokeThickness="1"
                                    Padding="10" Margin="0,4">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding Error.Message}"
                                           TextColor="Red" FontSize="12" />
                                    <Label Text="{Binding Error.RawLine}"
                                           FontSize="11" TextColor="Gray"
                                           FontFamily="Courier New" />
                                    <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto"
                                          ColumnSpacing="8" RowSpacing="6">
                                        <Label Grid.Row="0" Grid.Column="0" Text="Date:" VerticalOptions="Center" />
                                        <Entry Grid.Row="0" Grid.Column="1"
                                               Text="{Binding CorrectedDate}"
                                               Placeholder="yyyy-MM-dd" />

                                        <Label Grid.Row="1" Grid.Column="0" Text="Description:" VerticalOptions="Center" />
                                        <Entry Grid.Row="1" Grid.Column="1"
                                               Text="{Binding CorrectedDescription}" />

                                        <Label Grid.Row="2" Grid.Column="0" Text="Amount:" VerticalOptions="Center" />
                                        <Entry Grid.Row="2" Grid.Column="1"
                                               Text="{Binding CorrectedAmount}"
                                               Keyboard="Numeric" />
                                    </Grid>
                                    <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                        <Button Text="Apply"
                                                StyleClass="ApplyButton"
                                                BindingContext="{Binding .}"
                                                Clicked="OnApplyCorrectionClicked" />
                                        <Button Text="Skip"
                                                BindingContext="{Binding .}"
                                                Clicked="OnSkipErrorClicked" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom toolbar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Padding="16,12"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}">
            <Label x:Name="SummaryLabel"
                   Grid.Column="0"
                   VerticalOptions="Center"
                   FontSize="13" TextColor="Gray" />
            <Button Grid.Column="1"
                    Text="Import →"
                    Clicked="OnImportClicked" />
        </Grid>

    </Grid>

</ContentPage>
